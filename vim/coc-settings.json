{
	"coc.preferences.formatOnSaveFiletypes": ["css", "javascript", "json", "markdown", "python", "shell", "typescript", "typescriptreact"],
	"coc.preferences.formatOnType": true,
	"python.jediEnabled": true,
	"python.linting.pylintEnabled": false,
	"python.linting.flake8Enabled": true,
	"languageserver": {
		"bash": {
			"command": "bash-language-server",
			"args": ["start"],
			"filetypes": ["sh"],
			"ignoredRootPaths": ["~"]
		}
	}
}
