##### Prompt / Theme #####
# Custom Dracula prompt matching the tmux machine-color idea.
# Uses only Dracula palette colors.
setopt prompt_subst

_dotfiles_machine_accent() {
    local machine="${1:l}"
    case "$machine" in
        avon) print '#50fa7b' ;;   # Dracula green
        jimmy) print '#ff79c6' ;;  # Dracula pink
        lester) print '#f1fa8c' ;; # Dracula yellow
        *)
            local accents=(
                '#bd93f9' # purple
                '#ff79c6' # pink
                '#8be9fd' # cyan
                '#50fa7b' # green
                '#ffb86c' # orange
                '#f1fa8c' # yellow
                '#ff5555' # red
            )
            local sum=$(printf '%s' "$machine" | cksum | cut -d ' ' -f 1)
            print "$accents[$((sum % $#accents + 1))]"
            ;;
    esac
}

typeset -l DOTFILES_PROMPT_MACHINE
DOTFILES_PROMPT_MACHINE="$(hostname -s 2>/dev/null || hostname)"
DOTFILES_PROMPT_ACCENT="$(_dotfiles_machine_accent "$DOTFILES_PROMPT_MACHINE")"
# Keep the branch readable and distinct from the machine color.
DOTFILES_PROMPT_GIT_COLOR='#8be9fd' # Dracula cyan
[[ "$DOTFILES_PROMPT_GIT_COLOR" == "$DOTFILES_PROMPT_ACCENT" ]] && DOTFILES_PROMPT_GIT_COLOR='#50fa7b'

# Keep Python virtualenv activation from replacing the custom prompt.
# The prompt below renders the active venv name itself, which also works in Cursor terminals.
export VIRTUAL_ENV_DISABLE_PROMPT=1
_dotfiles_venv_prompt() {
    [[ -n "$VIRTUAL_ENV" ]] && print -r -- " %F{#ffb86c}(${VIRTUAL_ENV:t})%f"
}

autoload -Uz vcs_info
autoload -Uz add-zsh-hook
zstyle ':vcs_info:*' enable git
zstyle ':vcs_info:git:*' formats " %F{$DOTFILES_PROMPT_GIT_COLOR}%b%f"
zstyle ':vcs_info:git:*' actionformats ' %F{#ffb86c}%b:%a%f'
_dotfiles_update_vcs_info() { vcs_info }
add-zsh-hook precmd _dotfiles_update_vcs_info

PROMPT='%F{${DOTFILES_PROMPT_ACCENT}}${DOTFILES_PROMPT_MACHINE}%f$(_dotfiles_venv_prompt) %F{#bd93f9}%~%f${vcs_info_msg_0_} %F{${DOTFILES_PROMPT_ACCENT}}❯%f '
RPROMPT=''

sudo-command-line() {
    [[ -z $BUFFER ]] && zle up-history
    if [[ $BUFFER == sudo\ * ]]; then
        LBUFFER="${LBUFFER#sudo }"
    elif [[ $BUFFER == $EDITOR\ * ]]; then
        LBUFFER="${LBUFFER#$EDITOR }"
        LBUFFER="sudoedit $LBUFFER"
    elif [[ $BUFFER == sudoedit\ * ]]; then
        LBUFFER="${LBUFFER#sudoedit }"
        LBUFFER="$EDITOR $LBUFFER"
    else
        LBUFFER="sudo $LBUFFER"
    fi
}

