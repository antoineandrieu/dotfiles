# Pyenv configuration (add to PATH first, then init if available)
if [ -d "$HOME/.pyenv" ]; then
    export PATH="$HOME/.pyenv/bin:$PATH"
    if command -v pyenv 1>/dev/null 2>&1; then
        eval "$(pyenv init --path)"
        # Only run virtualenv-init if pyenv-virtualenv plugin is installed
        if pyenv commands 2>/dev/null | grep -q virtualenv-init; then
            eval "$(pyenv virtualenv-init -)"
        fi
    fi
fi

# Virtualenvwrapper configuration (only load if available)
if [ -f /usr/share/virtualenvwrapper/virtualenvwrapper.sh ]; then
    export WORKON_HOME=$HOME/.virtualenvs
    export VIRTUALENVWRAPPER_PYTHON=/usr/bin/python3
    source /usr/share/virtualenvwrapper/virtualenvwrapper.sh
elif [ -f "$HOME/.local/bin/virtualenvwrapper.sh" ]; then
    export WORKON_HOME=$HOME/.virtualenvs
    export VIRTUALENVWRAPPER_PYTHON=$HOME/.pyenv/versions/*/bin/python 2>/dev/null || export VIRTUALENVWRAPPER_PYTHON=/usr/bin/python3
    source "$HOME/.local/bin/virtualenvwrapper.sh"
fi

