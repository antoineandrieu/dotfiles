# Setup antigen base directory (auto-detect)
if [ -f "${${(%):-%x}:A:h}/antigen.zsh" ]; then
    # If zshrc is symlinked, resolve to actual file location
    ZSHA_BASE="${${(%):-%x}:A:h}"
else
    # Fallback to default location
    ZSHA_BASE=$HOME/sources/dotfiles/zsh
fi

PATH=$PATH:~/.local/bin

# Load antigen
source $ZSHA_BASE/antigen.zsh

# Load the oh-my-zsh's library
antigen use oh-my-zsh lib/

antigen bundle git
antigen bundle virtualenvwrapper

antigen bundle dracula/zsh
antigen theme dracula/zsh dracula

antigen apply

# Show hostname on right prompt with machine-specific color
case $HOST in
  avon) rprompt_color="green" ;;
  lester) rprompt_color="yellow" ;;
  *) rprompt_color="cyan" ;;
esac
RPROPT="%{%F{$rprompt_color}%}%m%{%f%}"

sudo-command-line() {
    [[ -z $BUFFER ]] && zle up-history
    if [[ $BUFFER == sudo\ * ]]; then
        LBUFFER="${LBUFFER#sudo }"
    elif [[ $BUFFER == $EDITOR\ * ]]; then
        LBUFFER="${LBUFFER#$EDITOR }"
        LBUFFER="sudoedit $LBUFFER"
    elif [[ $BUFFER == sudoedit\ * ]]; then
        LBUFFER="${LBUFFER#sudoedit }"
        LBUFFER="$EDITOR $LBUFFER"
    else
        LBUFFER="sudo $LBUFFER"
    fi
}

bindkey -s '^v' 'nvim $(fzf)^M'
bindkey '^f' fzf-cd-widget
zle -N sudo-command-line
# Defined shortcut keys: ss
bindkey "!!" sudo-command-line
bindkey -M vicmd '!!' sudo-command-line

cdl() { cd "$@" && ls; }

