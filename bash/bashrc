# Bash configuration - Machine name at beginning of prompt

# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return;;
esac

# History settings
HISTCONTROL=ignoreboth
HISTSIZE=1000
HISTFILESIZE=2000
shopt -s histappend

# Check window size after each command
shopt -s checkwinsize

# Prompt with machine name at the beginning
# \h = hostname (machine name)
# \w = working directory
# \$ = $ or # depending on user
PS1='\h:\w\$ '

# Colored prompt (optional - uncomment if terminal supports colors)
# PS1='\[\033[01;32m\]\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '

# Aliases
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
alias ..='cd ..'
alias ...='cd ../..'

# Source local bashrc if it exists (for machine-specific overrides)
if [ -f ~/.bashrc.local ]; then
    . ~/.bashrc.local
fi
